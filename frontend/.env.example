# Backend API base URL (required)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# IPFS gateway for displaying images and documents
# For Pinata: https://your-gateway.mypinata.cloud/ipfs
# For local dev with stub: http://localhost:3001/api/ipfs
NEXT_PUBLIC_IPFS_GATEWAY=http://localhost:3001/api/ipfs

# Chain ID (default: 31337 for local Hardhat, 11155111 for Sepolia)
NEXT_PUBLIC_CHAIN_ID=31337
